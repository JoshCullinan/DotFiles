-- =============================================================================
-- WezTerm Configuration
-- =============================================================================

local wezterm   = require 'wezterm'
local config    = wezterm.config_builder()
local act       = wezterm.action
local nerdfonts = wezterm.nerdfonts

-- Primary keybinding modifier — CMD on macOS, SUPER (Windows/Meta key) on
-- Linux. WezTerm treats CMD/SUPER/WIN as aliases internally, so changing this
-- one value flips every binding below to match the host OS conventions.
local mod       = '{{ if eq .chezmoi.os "darwin" }}CMD{{ else }}SUPER{{ end }}'
local mod_shift = mod .. '|SHIFT'
local mod_opt   = mod .. '|OPT'
local mod_ctrl  = mod .. '|CTRL'

-- Resolve a binary's absolute path via the login shell. WezTerm spawns
-- processes with a minimal PATH that excludes package-manager bin dirs
-- (Homebrew on macOS, ~/.local/bin on Linux), so installed tools must be
-- referenced by full path when passed to `args = {}` in a spawn action.
local function which(name)
  local shell = os.getenv('SHELL') or '/bin/sh'
  local ok, stdout = wezterm.run_child_process { shell, '-lc', 'command -v ' .. name }
  if ok then return (stdout:gsub('%s+$', '')) end
end

local shortcuts_path = wezterm.home_dir .. '/.config/wezterm/shortcuts.md'
local bat_path       = which 'bat'
local shortcuts_args = bat_path
    and { bat_path, '--paging=always', '--style=plain', shortcuts_path }
    or  { '/usr/bin/less', shortcuts_path }

