-- font_size: Linux clips glyph descenders/ascenders at smaller sizes — the
-- bitmap itself is rasterised clipped on this freetype/GPU pipeline, so
-- cell-metric knobs (line_height, etc.) can't fix it. 14 is the smallest
-- size that renders cleanly there. macOS is unaffected and stays at 13.5.
config.font_size   = {{ if eq .chezmoi.os "linux" }}14{{ else }}13.5{{ end }}
config.line_height = 1.2

